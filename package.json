{
  "name": "crush-acp",
  "version": "0.4.4",
  "description": "ACP adapter for Crush CLI - use Crush from Zed and other ACP-compatible editors",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "crush-acp": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "lint": "eslint src/",
    "test": "vitest"
  },
  "keywords": [
    "crush",
    "acp",
    "agent-client-protocol",
    "zed",
    "zed-editor",
    "ai",
    "coding-agent",
    "cli",
    "charmbracelet",
    "openai",
    "anthropic",
    "google-gemini",
    "deepseek",
    "mistral",
    "editor-integration",
    "llm"
  ],
  "author": "William Finger",
  "license": "MIT",
  "dependencies": {
    "@agentclientprotocol/sdk": "^0.17.1"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/willbnu/crush-acp"
  },
  "bugs": {
    "url": "https://github.com/willbnu/crush-acp/issues"
  },
  "homepage": "https://github.com/willbnu/crush-acp#readme"
